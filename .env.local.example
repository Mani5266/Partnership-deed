# ─── Supabase ──────────────────────────────────────────────────────────────────
# Required for database and file storage.
# Get these from your Supabase project dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for constructing verification/reset links in emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google Gemini AI ──────────────────────────────────────────────────────────
# Required for AI-assisted form filling, OCR, objective generation, name suggestions.
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Email (Resend — Primary) ─────────────────────────────────────────────────
# Required for email verification and password reset in production.
# Get your key at https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# ─── Email (Mailjet — Fallback) ───────────────────────────────────────────────
# Optional fallback email provider. Both keys required to enable.
# Get keys at https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=your_mailjet_api_key_here
MAILJET_SECRET_KEY=your_mailjet_secret_key_here

# ─── Email Sender ─────────────────────────────────────────────────────────────
# The "from" address for all transactional emails.
EMAIL_FROM=noreply@yourdomain.com

# ─── Rate Limiting (Upstash Redis) ────────────────────────────────────────────
# Optional for local development (rate limiting disabled without these).
# Required in production. Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
